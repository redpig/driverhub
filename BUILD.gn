# ---------------------------------------------------------------------------
# DriverHub runner — serves fuchsia.component.runner.ComponentRunner for .ko
# ---------------------------------------------------------------------------

source_set("driverhub-runner-lib") {
  sources = [
    "src/runner/ko_runner.cc",
    "src/runner/ko_runner.h",
    "src/runner/process_manager.cc",
    "src/runner/process_manager.h",
    "src/runner/symbol_proxy_server.cc",
    "src/runner/symbol_proxy_server.h",
    "src/runner/symbol_registry_server.cc",
    "src/runner/symbol_registry_server.h",
  ]

  public_deps = [
    ":driverhub-core",
    "//sdk/fidl/fuchsia.component.runner:fuchsia.component.runner_cpp",
    "//sdk/fidl/fuchsia.driverhub:fuchsia.driverhub_cpp",
    "//sdk/lib/component/outgoing/cpp",
    "//sdk/lib/fdio",
    "//src/lib/elfldltl",
    "//zircon/system/ulib/async-loop:async-loop-cpp",
    "//zircon/system/ulib/zx",
  ]

  include_dirs = [
    ".",
    "src/shim/include",
  ]
}

executable("driverhub_runner") {
  output_name = "driverhub_runner"

  sources = [
    "src/runner/main.cc",
  ]

  deps = [
    ":driverhub-runner-lib",
    "//sdk/lib/component/outgoing/cpp",
    "//zircon/system/ulib/async-loop:async-loop-cpp",
    "//zircon/system/ulib/async-loop:async-loop-default",
  ]

