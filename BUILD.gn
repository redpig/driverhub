import("//build/bind/bind.gni")
import("//build/components.gni")
import("//build/drivers.gni")

group("driverhub") {
  deps = [
    ":driverhub-component",
    ":driverhub-runner-component",
    ":driverhub-tests",
  ]
}

# Bind rules: match the driverhub bus driver to the platform device.
driver_bind_rules("driverhub-bind") {
  rules = "meta/driverhub.bind"
  deps = [
    "//src/devices/bind/fuchsia.platform",
  ]
}

# Core static library shared between the driver and tests.
source_set("driverhub-core") {
  sources = [
    "src/dt/dt_provider.cc",
    "src/fuchsia/service_bridge.cc",
    "src/fuchsia/service_bridge.h",
    "src/loader/dependency_sort.cc",
    "src/loader/memory_allocator.cc",
    "src/loader/modinfo_parser.cc",
    "src/loader/module_loader.cc",
    "src/module_node/module_node.cc",
    "src/shim/kernel/bug.cc",
    "src/shim/kernel/device.cc",
    "src/shim/kernel/io.cc",
    "src/shim/kernel/irq.cc",
    "src/shim/kernel/memory.cc",
    "src/shim/kernel/module.cc",
    "src/shim/kernel/platform.cc",
    "src/shim/kernel/print.cc",
    "src/shim/kernel/sync.cc",
    "src/shim/kernel/time.cc",
    "src/shim/kernel/timer.cc",
    "src/shim/kernel/workqueue.cc",
    "src/shim/subsystem/cfg80211.cc",
    "src/shim/subsystem/drm.cc",
    "src/shim/subsystem/fs.cc",
    "src/shim/subsystem/gpio.cc",
    "src/shim/subsystem/i2c.cc",
    "src/shim/subsystem/input.cc",
    "src/shim/subsystem/rtc.cc",
    "src/shim/subsystem/spi.cc",
    "src/shim/subsystem/usb.cc",
    "src/symbols/symbol_registry.cc",
  ]

  public_deps = [
    "//sdk/lib/driver/logging/cpp",
    "//src/lib/elfldltl",
    "//zircon/system/ulib/zx",
  ]

  include_dirs = [
    ".",
    "src/shim/include",
  ]
}

# The DFv2 bus driver component.
fuchsia_driver("driverhub-driver") {
  output_name = "driverhub"

  sources = [
    "src/fuchsia/driverhub_driver.cc",
    "src/fuchsia/driverhub_driver.h",
    "src/fuchsia/gpio_service_server.cc",
    "src/fuchsia/gpio_service_server.h",
    "src/fuchsia/module_child_node.cc",
    "src/fuchsia/module_child_node.h",
    "src/fuchsia/module_enumerator.cc",
    "src/fuchsia/module_enumerator.h",
    "src/fuchsia/resource_provider.cc",
    "src/fuchsia/resource_provider.h",
    "src/fuchsia/service_bridge.cc",
    "src/fuchsia/service_bridge.h",
    "src/fuchsia/vmo_module_loader.cc",
    "src/fuchsia/vmo_module_loader.h",
  ]

  deps = [
    ":driverhub-bind",
    ":driverhub-core",
    "//sdk/fidl/fuchsia.driver.framework:fuchsia.driver.framework_cpp",
    "//sdk/fidl/fuchsia.hardware.gpio:fuchsia.hardware.gpio_cpp",
    "//sdk/fidl/fuchsia.hardware.i2c:fuchsia.hardware.i2c_cpp",
    "//sdk/fidl/fuchsia.hardware.platform.device:fuchsia.hardware.platform.device_cpp",
    "//sdk/fidl/fuchsia.hardware.spi:fuchsia.hardware.spi_cpp",
    "//sdk/lib/driver/component/cpp",
    "//sdk/lib/driver/incoming/cpp",
    "//sdk/lib/driver/outgoing/cpp",
    "//sdk/lib/fdio",
    "//src/lib/elfldltl",
  ]

  include_dirs = [
    ".",
    "src/shim/include",
  ]
}

fuchsia_driver_component("driverhub-component") {
  component_name = "driverhub"
  manifest = "meta/driverhub.cml"
  deps = [ ":driverhub-driver" ]
  info = "meta/driverhub-info.json"
}

