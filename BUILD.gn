  ]
}

fuchsia_component("driverhub-runner-component") {
  component_name = "driverhub-runner"
  manifest = "meta/driverhub-runner.cml"
  deps = [
    ":driverhub_runner",
    ":libdriverhub_kmi",
  ]
}

# Template for packaging a .ko module as a Fuchsia component.
#
# Usage:
#   ko_module("bmp280") {
#     ko_binary = "path/to/bmp280.ko"
#     manifest = "meta/bmp280.cml"
#   }
template("ko_module") {
  fuchsia_component(target_name) {
    component_name = target_name
    manifest = invoker.manifest
    deps = []
    if (defined(invoker.deps)) {
      deps += invoker.deps
    }
    resources = [
      {
        path = invoker.ko_binary
        dest = "data/modules/" + get_path_info(invoker.ko_binary, "file")
      },
    ]
  }
}

# ---------------------------------------------------------------------------
# Unit tests.
# ---------------------------------------------------------------------------

fuchsia_unittest_package("driverhub-tests") {
  deps = [ ":driverhub-unittests" ]
}

fuchsia_test_component("driverhub-unittests") {
  manifest = "meta/driverhub-tests.cml"
  deps = [ ":driverhub-test-bin" ]
}

executable("driverhub-test-bin") {
  testonly = true
  output_name = "driverhub-tests"

  sources = [
    "tests/dependency_sort_test.cc",
    "tests/loader_test.cc",
    "tests/modinfo_parser_test.cc",
    "tests/symbol_registry_test.cc",
  ]

  deps = [
    ":driverhub-core",
    "//src/lib/fxl/test:gtest_main",
    "//third_party/googletest:gtest",
  ]

  include_dirs = [
    ".",
    "src/shim/include",
  ]
}
